# Dev local (docker compose up -d) :
DATABASE_URL=postgresql://dc_user:dc_password@localhost:5432/deathchallenge
# Prod (Neon) : coller la "connection string" fournie par le dashboard Neon,
# elle ressemble a postgresql://user:password@ep-xxx.aws.neon.tech/dbname
# La connexion SSL est activee automatiquement des que l'hote n'est pas local
# (voir backend/src/db/index.js), pas besoin de parametre supplementaire.

JWT_SECRET=change-me-with-a-long-random-string
PORT=3001
CORS_ORIGIN=http://localhost:5173
